# Player Settings
player=mpv

# Player arguments (passed to the player)
player-args=--no-border --no-keepaspect-window --window-maximized=yes --loop-playlist=inf --loop-file=inf --cache=yes --demuxer-max-back-bytes=120M

# Stream Settings
stream-segment-threads=2
hls-live-edge=1

# Twitch Settings
twitch-disable-ads
twitch-low-latency

# Default Stream Quality
default-stream=best
